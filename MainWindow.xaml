<Window x:Class="ClaudeSessionManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClaudeSessionManager.ViewModels"
        Title="Claude Sessions"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="450"
        SizeToContent="Height"
        ResizeMode="NoResize">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Border x:Name="RootBorder"
            Background="#E61E1E2E"
            CornerRadius="10">
        <StackPanel>
            <Border x:Name="DragHandle"
                    Padding="12,8,8,6"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="8"
                                Height="8"
                                Margin="0,0,6,0"
                                Background="#CBA6F7"
                                CornerRadius="2"
                                VerticalAlignment="Center" />
                        <TextBlock Text="Claude Sessions"
                                   Foreground="#CDD6F4"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="X"
                            FontSize="10"
                            Width="20"
                            Height="20"
                            Background="Transparent"
                            Foreground="#585B70"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#F38BA8" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <Rectangle Height="1" Fill="#313244" Margin="8,0" />

            <ItemsControl ItemsSource="{Binding Sessions}"
                          Margin="0,4,0,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch"
                                Command="{Binding DataContext.FocusWindowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="RowBg"
                                            Background="Transparent"
                                            Padding="12,5,12,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Grid.Column="0"
                                                     Width="7"
                                                     Height="7"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#45475A" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAlive}" Value="True">
                                                                <Setter Property="Fill" Value="#A6E3A1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <StackPanel Grid.Column="1"
                                                        Margin="8,0,8,0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ProjectName}"
                                                           Foreground="#8cff9d"
                                                           FontSize="16"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding WindowTitle}"
                                                           Foreground="#a3c8e3"
                                                           FontSize="14"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding WindowTitle, Converter={StaticResource StringToVisibilityConverter}}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding ElapsedTime}"
                                                           Foreground="#585B70"
                                                           FontSize="10"
                                                           HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding LastActivityText}"
                                                           Foreground="#A6E3A1"
                                                           FontSize="10"
                                                           HorizontalAlignment="Right"
                                                           Visibility="{Binding LastActivityText, Converter={StaticResource StringToVisibilityConverter}}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RowBg" Property="Background" Value="#1ACDD6F4" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="No sessions"
                       Foreground="#45475A"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,10">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Sessions.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Border>
</Window>
