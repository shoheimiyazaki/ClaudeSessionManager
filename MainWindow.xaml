<Window x:Class="ClaudeSessionManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClaudeSessionManager.ViewModels"
        Title="Claude Sessions"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="540"
        Height="720"
        ResizeMode="NoResize">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#7F849C" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#E6E9F2" />
                                <Setter Property="Background" Value="#22313B52" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#E8ECF7" />
            <Setter Property="Background" Value="#32405A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.78" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetaBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#20313B52" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="#EE171A28"
            BorderBrush="#503B425C"
            BorderThickness="1"
            CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    x:Name="DragHandle"
                    Padding="16,12,10,10"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="10"
                                Height="10"
                                Margin="0,0,8,0"
                                Background="#72E6A4"
                                CornerRadius="3"
                                VerticalAlignment="Center" />
                        <StackPanel>
                            <TextBlock Text="CLI Sessions"
                                   Foreground="#F4F6FB"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="Live and archived terminal sessions"
                                       Foreground="#8690AF"
                                       FontSize="10" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Close"
                            FontSize="11"
                            Padding="10,5"
                            Background="#22313B52"
                            Foreground="#AAB3CF"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#F8D6DF" />
                                        <Setter Property="Background" Value="#6A3545" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <Rectangle Grid.Row="1" Height="1" Fill="#2E354C" Margin="12,0" />

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,10,12,6">
                <Button Command="{Binding SelectActiveTabCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                    <Setter Property="Foreground" Value="#F4F6FB" />
                                    <Setter Property="Background" Value="#2B3651" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Active" />
                </Button>

                <Button Command="{Binding SelectArchivedTabCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                    <Setter Property="Foreground" Value="#F4F6FB" />
                                    <Setter Property="Background" Value="#2B3651" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Archived" />
                </Button>
            </StackPanel>

            <Rectangle Grid.Row="3" Height="1" Fill="#2E354C" Margin="12,0" />

            <ScrollViewer Grid.Row="4"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,6,0,10">
                <StackPanel>
                    <ItemsControl x:Name="SessionList"
                                  ItemsSource="{Binding CurrentSessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        HorizontalContentAlignment="Stretch"
                                        Click="SessionItem_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="RowBg"
                                                    Margin="10,4"
                                                    Padding="14,12"
                                                    Background="#F0141B2B"
                                                    BorderBrush="#2C344A"
                                                    BorderThickness="1"
                                                    CornerRadius="14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Grid.Column="0"
                                                          Margin="0,0,12,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <DockPanel Grid.Row="0" LastChildFill="True">
                                                            <StackPanel DockPanel.Dock="Right"
                                                                        Orientation="Horizontal">
                                                                <Border Style="{StaticResource MetaBadgeStyle}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Ellipse Width="8"
                                                                                 Height="8"
                                                                                 Margin="0,0,6,0"
                                                                                 VerticalAlignment="Center">
                                                                            <Ellipse.Style>
                                                                                <Style TargetType="Ellipse">
                                                                                    <Setter Property="Fill" Value="#7F849C" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsAlive}" Value="True">
                                                                                            <Setter Property="Fill" Value="#72E6A4" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Ellipse.Style>
                                                                        </Ellipse>
                                                                        <TextBlock Foreground="#D7DDF0"
                                                                                   FontSize="10"
                                                                                   VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="Idle" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsAlive}" Value="True">
                                                                                            <Setter Property="Text" Value="Live" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource MetaBadgeStyle}"
                                                                        Background="#28384F">
                                                                    <TextBlock Text="{Binding SourceLabel}"
                                                                               Foreground="#DCE4F8"
                                                                               FontSize="10" />
                                                                </Border>
                                                            </StackPanel>

                                                            <TextBlock Text="{Binding ProjectName}"
                                                                       Foreground="#7DF0A3"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center" />
                                                        </DockPanel>

                                                        <TextBlock Grid.Row="1"
                                                                   Margin="0,7,0,0"
                                                                   Text="{Binding SubtitleText}"
                                                                   Foreground="#AFC8DE"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding SubtitleText}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEditingTitle}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding SubtitleText}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <TextBox Grid.Row="1"
                                                                 Margin="0,7,0,0"
                                                                 Text="{Binding CustomTitle, UpdateSourceTrigger=PropertyChanged}"
                                                                 Foreground="#E8ECF7"
                                                                 Background="#222B3F"
                                                                 BorderBrush="#6E8FD8"
                                                                 BorderThickness="1"
                                                                 CaretBrush="#E8ECF7"
                                                                 SelectionBrush="#6E8FD8"
                                                                 FontSize="12"
                                                                 Padding="8,5"
                                                                 KeyDown="RenameBox_KeyDown"
                                                                 LostFocus="RenameBox_LostFocus"
                                                                 IsVisibleChanged="RenameBox_IsVisibleChanged">
                                                            <TextBox.Style>
                                                                <Style TargetType="TextBox">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEditingTitle}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>

                                                        <StackPanel Grid.Row="2"
                                                                    Margin="0,10,0,0"
                                                                    Orientation="Horizontal">
                                                            <Border Style="{StaticResource MetaBadgeStyle}">
                                                                <TextBlock Text="{Binding ElapsedTime}"
                                                                           Foreground="#D3D9EC"
                                                                           FontSize="10" />
                                                            </Border>
                                                            <Border Style="{StaticResource MetaBadgeStyle}"
                                                                    Visibility="{Binding LastActivityText, Converter={StaticResource StringToVisibilityConverter}}">
                                                                <TextBlock Text="{Binding LastActivityText}"
                                                                           Foreground="#9DE5B5"
                                                                           FontSize="10" />
                                                            </Border>
                                                            <TextBlock Text="{Binding ProjectPath}"
                                                                       Margin="4,2,0,0"
                                                                       Foreground="#6F7898"
                                                                       FontSize="10"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center"
                                                                       ToolTip="{Binding ProjectPath}"
                                                                       Visibility="{Binding ProjectPath, Converter={StaticResource StringToVisibilityConverter}}" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Stretch"
                                                                HorizontalAlignment="Right">
                                                        <Button Content="{Binding StarGlyph}"
                                                                Width="30"
                                                                Height="30"
                                                                Margin="0,0,0,10"
                                                                HorizontalAlignment="Right"
                                                                BorderThickness="0"
                                                                Cursor="Hand"
                                                                ToolTip="Toggle star"
                                                                Command="{Binding DataContext.ToggleStarCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Background" Value="#16202F" />
                                                                    <Setter Property="Foreground" Value="#6D7594" />
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border Background="{TemplateBinding Background}"
                                                                                        CornerRadius="15">
                                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                                      VerticalAlignment="Center" />
                                                                                </Border>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Foreground" Value="#F4DC8A" />
                                                                            <Setter Property="Background" Value="#253148" />
                                                                        </Trigger>
                                                                        <DataTrigger Binding="{Binding IsStarred}" Value="True">
                                                                            <Setter Property="Foreground" Value="#F4DC8A" />
                                                                            <Setter Property="Background" Value="#253148" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>

                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Bottom">
                                                            <Button Content="Archive"
                                                                    ToolTip="Archive"
                                                                    Command="{Binding DataContext.ArchiveSessionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DataContext.SelectedTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="1">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>

                                                            <Button Content="Restore"
                                                                    ToolTip="Restore"
                                                                    Command="{Binding DataContext.RestoreSessionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding DataContext.SelectedTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="1" />
                                                                                    <Condition Binding="{Binding CanRestore}" Value="True" />
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>

                                                            <Button Content="Delete"
                                                                    ToolTip="Delete"
                                                                    Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                                        <Setter Property="Margin" Value="0" />
                                                                        <Setter Property="Background" Value="#653848" />
                                                                        <Setter Property="Foreground" Value="#F8DFE5" />
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RowBg" Property="Background" Value="#FF1A2235" />
                                                    <Setter TargetName="RowBg" Property="BorderBrush" Value="#425172" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                                    <Setter TargetName="RowBg" Property="Opacity" Value="0.88" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No sessions"
                               Foreground="#68728F"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,18,0,14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=SessionList, Path=HasItems}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
