<Window x:Class="ClaudeSessionManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClaudeSessionManager.ViewModels"
        Title="Claude Sessions"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="450"
        Height="650"
        ResizeMode="NoResize">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- タブボタン共通スタイル（アンダーライン付き） -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#45475A"/>
            <Setter Property="BorderBrush"      Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0,0,0,2"/>
            <Setter Property="Padding"          Value="14,5"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background      ="{TemplateBinding Background}"
                                BorderBrush    ="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding        ="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ドラッグ移動用: ヘッダー部分だけ DragMove -->
    <Border Background="#E61E1E2E"
            CornerRadius="10"
            x:Name="RootBorder">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== ヘッダー ===== -->
            <Border Grid.Row="0"
                    x:Name="DragHandle"
                    Padding="12,8,8,6"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Claude アイコン風の小さな四角 -->
                        <Border Width="8" Height="8"
                                Background="#CBA6F7"
                                CornerRadius="2"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Claude Sessions"
                                   Foreground="#CDD6F4"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 閉じるボタン -->
                    <Button Grid.Column="1"
                            Content="✕"
                            FontSize="10"
                            Width="20" Height="20"
                            Background="Transparent"
                            Foreground="#585B70"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#F38BA8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- 区切り線 -->
            <Rectangle Grid.Row="1" Height="1" Fill="#313244" Margin="8,0"/>

            <!-- ===== タブ ===== -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,0">

                <!-- アクティブタブ -->
                <Button Command="{Binding SelectActiveTabCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                    <Setter Property="Foreground"  Value="#CDD6F4"/>
                                    <Setter Property="BorderBrush" Value="#CBA6F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="アクティブ" FontSize="11"/>
                </Button>

                <!-- アーカイブタブ -->
                <Button Command="{Binding SelectArchivedTabCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                    <Setter Property="Foreground"  Value="#CDD6F4"/>
                                    <Setter Property="BorderBrush" Value="#CBA6F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="アーカイブ" FontSize="11"/>
                </Button>

            </StackPanel>

            <!-- 区切り線 -->
            <Rectangle Grid.Row="3" Height="1" Fill="#313244" Margin="8,0"/>

            <!-- ===== セッションリスト（スクロール可） ===== -->
            <ScrollViewer Grid.Row="4"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,4,0,6">
                <StackPanel>

                    <ItemsControl x:Name="SessionList"
                                  ItemsSource="{Binding CurrentSessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        HorizontalContentAlignment="Stretch"
                                        Click="SessionItem_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="RowBg"
                                                    Background="Transparent"
                                                    Padding="12,5,8,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="28"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- ステータスドット -->
                                                    <Ellipse Grid.Column="0"
                                                             Width="7" Height="7"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#45475A"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAlive}" Value="True">
                                                                        <Setter Property="Fill" Value="#A6E3A1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>

                                                    <!-- プロジェクト名(常時主表示) + 補助情報(カスタムタイトル / 履歴先頭メッセージ / WindowTitle) -->
                                                    <StackPanel Grid.Column="1"
                                                                Margin="8,0,8,0"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ProjectName}"
                                                                   Foreground="#8cff9d"
                                                                   FontSize="16"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <!-- 通常表示: SubtitleText -->
                                                        <TextBlock Text="{Binding SubtitleText}"
                                                                   Foreground="#a3c8e3"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding SubtitleText}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <!-- 編集中は TextBox と入れ替え -->
                                                                        <DataTrigger Binding="{Binding IsEditingTitle}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <!-- サブタイトルが空なら非表示 -->
                                                                        <DataTrigger Binding="{Binding SubtitleText}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <!-- 編集中: カスタムタイトル入力 TextBox -->
                                                        <TextBox Text="{Binding CustomTitle, UpdateSourceTrigger=PropertyChanged}"
                                                                 Foreground="#CDD6F4"
                                                                 Background="#313244"
                                                                 BorderBrush="#CBA6F7"
                                                                 BorderThickness="1"
                                                                 CaretBrush="#CDD6F4"
                                                                 SelectionBrush="#CBA6F7"
                                                                 FontSize="12"
                                                                 Padding="2,1"
                                                                 KeyDown="RenameBox_KeyDown"
                                                                 LostFocus="RenameBox_LostFocus"
                                                                 IsVisibleChanged="RenameBox_IsVisibleChanged">
                                                            <TextBox.Style>
                                                                <Style TargetType="TextBox">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEditingTitle}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>
                                                    </StackPanel>

                                                    <!-- 右側: 経過時間 + 最終メッセージ -->
                                                    <StackPanel Grid.Column="2"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding ElapsedTime}"
                                                                   Foreground="#585B70"
                                                                   FontSize="10"
                                                                   HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding LastActivityText}"
                                                                   Foreground="#A6E3A1"
                                                                   FontSize="10"
                                                                   HorizontalAlignment="Right"
                                                                   Visibility="{Binding LastActivityText,
                                                                       Converter={StaticResource StringToVisibilityConverter}}"/>
                                                    </StackPanel>

                                                    <!-- アーカイブボタン（非アーカイブ時のみ表示） -->
                                                    <Button Grid.Column="3"
                                                            Content="−"
                                                            FontSize="13"
                                                            Width="22" Height="22"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            ToolTip="アーカイブ"
                                                            Command="{Binding DataContext.ArchiveCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="Foreground" Value="#45475A"/>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Foreground" Value="#A6ADC8"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <!-- 復元ボタン（アーカイブ時のみ表示） -->
                                                    <Button Grid.Column="3"
                                                            Content="↩"
                                                            FontSize="12"
                                                            Width="22" Height="22"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            ToolTip="アーカイブから復元"
                                                            Command="{Binding DataContext.RestoreCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="Foreground" Value="#45475A"/>
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Foreground" Value="#A6E3A1"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RowBg" Property="Background" Value="#1ACDD6F4"/>
                                                </Trigger>
                                                <!-- 終了済みセッションを半透明表示 -->
                                                <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                                    <Setter TargetName="RowBg" Property="Opacity" Value="0.45"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- セッションなし表示 -->
                    <TextBlock Text="セッションなし"
                               Foreground="#45475A"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=SessionList, Path=HasItems}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>
